@startuml
title Платформа Краудфандинга - Maintenance & Deployment

!define ICON_MICROSERVICE <color:#4477aa><&cloud></color>
!define ICON_DATABASE <color:#44aa77><&database></color>
!define ICON_SECURITY <color:#aa4444><&shield></color>
!define ICON_MONITOR <color:#aa8844><&eye></color>
!define ICON_AUTOMATE <color:#7744aa><&cog></color>

skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam componentStyle rectangle
skinparam backgroundColor #FEFDFA
skinparam card {
  BorderColor #4477aa
  BorderThickness 1
  BackgroundColor #F8F9FA
  FontColor #2E4053
}
skinparam note {
  BorderColor #888888
  BackgroundColor #FFF9E6
}
skinparam arrow {
  Color #666666
  Thickness 1
}
skinparam rectangle {
  BorderColor #AAAAAA
  BackgroundColor #EEEEEE
  FontStyle bold
}

' === ЦВЕТОВЫЕ КАТЕГОРИИ ===
' CI/CD: синий (#4477aa)
' Мониторинг: оранжевый (#aa8844)
' Обслуживание: зеленый (#44aa77)
' Автоматизация: фиолетовый (#7744aa)
' Безопасность: красный (#aa4444)

' === CI/CD PIPELINE (СЖАТАЯ ВЕРСИЯ) ===
rectangle "<size:14><b>CI/CD Pipeline</b></size>" as cicd_parent #4477aa {
  
  card "<b>Development</b>" <<dev>> #D4E6F1 {
    card "Git Feature Branches" as git
    card "🔨 Build & Test" as build {
      card "Backend: Docker + Unit/Integ" as build_be
      card "Frontend: Build + Jest/E2E" as build_fe
    }
    card "🔒 Security Scan" as security_scan
    card "⚡ Load Testing (k6)" as perf
  }
  
  card "<b>Staging</b>" <<stage>> #D5E8D4 {
    card "Deploy to Staging K8s" as staging_deploy
    card "📱 Fastlane (Beta)" as fastlane_beta
    card "Payment Simulation" as payment_sim
    card "API Contract Tests" as api_tests
  }
  
  card "<b>Production</b>" <<prod>> #FAD7A0 {
    card "Blue-Green Deployment" as bluegreen
    card "📱 Fastlane (Store)" as fastlane_prod
    card "Payment Gateway Sync" as payment_sync
    database "Production K8s Cluster" as k8s_prod
  }
}

' === MONITORING (ГРУППИРОВАННЫЙ) ===
rectangle "<size:14><b>Monitoring & Observability</b></size>" as monitoring_parent #aa8844 {
  
  card "<b>Metrics & Logs</b>" #FFF2CC {
    card "Prometheus" as prometheus
    card "ELK Stack" as elk_logs
    card "Jaeger (Tracing)" as tracing
    card "Sentry" as sentry
  }
  
  card "<b>Visualization & Alerts</b>" #FFF2CC {
    card "Grafana Dashboards" as grafana
    card "AlertManager" as alertmanager
    card "Fraud Detection" as fraud_alerts
  }
}

' === MAINTENANCE (КАТЕГОРИЗИРОВАННЫЙ) ===
rectangle "<size:14><b>Maintenance Procedures</b></size>" as maintenance_parent #44aa77 {
  
  card "<b>Database</b>" #D5E8D4 {
    card "PostgreSQL (VACUUM, indexes)" as pg_maint
    card "ClickHouse (partitions)" as ch_maint
    card "Elasticsearch (reindex)" as es_maint
  }
  
  card "<b>Infrastructure</b>" #D5E8D4 {
    card "RabbitMQ / Redis" as middleware_maint
    card "S3 Lifecycle" as s3_maint
    card "Daily Backups (Wal-G)" as backups
    card "SSL Renewal" as ssl
  }
  
  card "<b>Business</b>" #D5E8D4 {
    card "Payment Reconciliation" as payment_recon
  }
}

' === AUTOMATION ===
rectangle "<size:14><b>Automation</b></size>" as automation_parent #7744aa {
  
  card "<b>Infrastructure as Code</b>" #E1D5E7 {
    card "GitOps (ArgoCD)" as argocd
    card "Terraform" as terraform
  }
  
  card "<b>Operations</b>" #E1D5E7 {
    card "DB Migrations (Flyway)" as migrations
    card "Auto-scaling Policies" as autoscaling
    card "Scheduled Jobs" as cron_jobs
  }
}

' === COMPLIANCE & DR ===
rectangle "<size:14><b>Compliance & DR</b></size>" as compliance_parent #aa4444 {
  
  card "<b>Compliance</b>" #F9D7D7 {
    card "PCI DSS / GDPR" as compliance
    card "Security Audits" as audits
  }
  
  card "<b>Disaster Recovery</b>" #F9D7D7 {
    card "Multi-region Replication" as dr_multiregion
    card "Backup Drills / Failover" as dr_procedures
  }
}

' === SLIs (ВЫНЕСЕНЫ ОТДЕЛЬНО) ===
card "<b>Service Level Indicators</b>" as sli_card #FAD7A0 {
  together {
    card "Payment Success >99.9%" as payment_sli
    card "Project Load <2s" as project_sli
  }
  together {
    card "Search Latency <500ms" as search_sli
    card "Notification <5s" as notification_sli
  }
  card "Moderation Queue <24h" as moderation_sli
}

' === КЛЮЧЕВЫЕ СВЯЗИ (ТОЛЬКО ГЛАВНЫЕ) ===
git --> build
build --> staging_deploy
staging_deploy --> api_tests
api_tests --> bluegreen
bluegreen --> k8s_prod
fastlane_beta --> fastlane_prod

' Мониторинг
k8s_prod --> prometheus
k8s_prod --> elk_logs
prometheus --> grafana
elk_logs --> grafana
fraud_alerts --> alertmanager

' Автоматизация
argocd --> k8s_prod
terraform --> k8s_prod
migrations --> k8s_prod
autoscaling --> k8s_prod

' Метрики
prometheus --> payment_sli
prometheus --> project_sli
elk_logs --> moderation_sli

' === УЛУЧШЕННЫЕ КОММЕНТАРИИ (МЕНЬШЕ, НО ИНФОРМАТИВНЕЕ) ===
note top of build_be
  <b>Multi-language Build</b>
  Node.js, Python, Java
  Docker containers
end note

note top of fastlane_beta
  <b>Mobile DevOps</b>
  TestFlight / Beta releases
  Certificate management
end note

note top of payment_sim
  <b>Payment Testing</b>
  Stripe, Tinkoff, PayPal
  Sandbox environments
  Edge cases simulation
end note

note left of tracing
  <b>Distributed Tracing</b>
  End-to-end payment flow
  Performance bottleneck detection
end note

note right of fraud_alerts
  <b>Anti-fraud Monitoring</b>
  Suspicious transactions
  Automated blocking
  Pattern detection
end note

note left of pg_maint
  <b>PostgreSQL Care</b>
  VACUUM, statistics, indexes
  Deadlock monitoring
end note

note right of backups
  <b>Wal-G Backups</b>
  Point-in-time recovery
  Daily full + WAL archiving
  Cross-region replication
end note

note left of payment_recon
  <b>Daily Reconciliation</b>
  Payment gateway matching
  Discrepancy resolution
  Financial reports
end note

note right of autoscaling
  <b>Auto-scaling</b>
  HPA based on load
  Scale-to-zero off-peak
  Burst handling
end note

note left of compliance
  <b>Compliance</b>
  PCI DSS for payments
  GDPR for user data
  Regular audits
end note

note right of dr_multiregion
  <b>Multi-region DR</b>
  Primary: eu-west-1
  Standby: eu-central-1
  DNS failover (Route53)
end note

note bottom of k8s_prod
  <b>Production Environment</b>
  • Microservices (Node.js, Python, Java)
  • PostgreSQL + ClickHouse
  • Elasticsearch + Redis
  • RabbitMQ + S3
  <i>High availability across AZs</i>
end note

' === ВИЗУАЛЬНОЕ РАЗДЕЛЕНИЕ ===
footer %filename% - Optimized for readability

@enduml