@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Deployment.puml

title Платформа Краудфандинга

' === ВНЕШНИЕ ПОЛЬЗОВАТЕЛИ ===
Person(author, "Автор проекта", "Создает проекты")
Person(backer, "Спонсор", "Финансирует проекты")
Person(moderator, "Модератор", "Проверяет проекты")

' === КЛАСТЕР KUBERNETES ===
Deployment_Node(k8s_cluster, "Kubernetes Cluster", "AWS EKS (4 ноды)") {
    
    ' === Gateway Layer ===
    Deployment_Node(gateway, "Gateway Layer", "ingress-nginx + Spring Cloud Gateway") {
        Container(api_gateway, "API Gateway", "Spring Cloud Gateway", "Маршрутизация, аутентификация")
        Container(web_frontend, "Web Frontend", "React", "SPA (3 реплики)")
    }
    
    ' === Business Logic Layer ===
    Deployment_Node(services, "Microservices", "Бизнес-логика (масштабирование)") {
        Container(auth_service, "Auth Service", "Node.js", "Аутентификация, пользователи | 3 реплики")
        Container(project_service, "Project Service", "Python FastAPI", "Управление проектами | 3 реплики")
        Container(payment_service, "Payment Service", "Java Spring", "Платежи, транзакции | 3 реплики")
        Container(search_service, "Search Service", "Python", "Поиск проектов | 2 реплики")
        Container(notification_service, "Notification Service", "Node.js", "Уведомления | 2 реплики")
        Container(analytics_service, "Analytics Service", "Python", "Аналитика | 2 реплики")
        Container(moderation_service, "Moderation Service", "Python", "Модерация | 2 реплики")
    }
    
    ' === Infrastructure Layer ===
    Deployment_Node(infra, "Infrastructure Services", "Системные компоненты") {
        Container(rabbitmq, "RabbitMQ", "Message Broker", "Кластер 3 ноды")
        Container(redis, "Redis", "Cache & Sessions", "Кластер 3 ноды")
        Container(elasticsearch, "Elasticsearch", "Search Index", "Кластер 3 ноды")
    }
}

' === DATA LAYER (Managed Services) ===
Deployment_Node(data_layer, "Data Layer", "AWS Managed Services") {
    
    Deployment_Node(postgres, "PostgreSQL Cluster", "Aurora Serverless") {
        ContainerDb(postgres_primary, "PostgreSQL Primary", "Aurora", "Операционные данные")
        ContainerDb(postgres_replica, "PostgreSQL Replica", "Aurora", "Чтение, отчеты")
    }
    
    Deployment_Node(analytics, "Analytics Database", "ClickHouse") {
        ContainerDb(clickhouse, "ClickHouse", "Analytics DB", "Аналитические данные")
    }
    
    Deployment_Node(storage, "Object Storage", "Amazon S3") {
        ContainerDb(s3, "S3 Bucket", "Media Storage", "Файлы проектов")
    }
}

' === MONITORING ===
Deployment_Node(monitoring, "Monitoring", "Observability Stack") {
    Container(prometheus, "Prometheus", "Metrics", "Сбор метрик")
    Container(grafana, "Grafana", "Visualization", "Дашборды")
    Container(jaeger, "Jaeger", "Tracing", "Трассировка")
    Container(loki_stack, "Loki + Promtail", "Logging", "Сбор и хранение логов")
}

' === EXTERNAL SYSTEMS ===
System_Ext(payment_gateway, "Payment Gateway", "Stripe/Tinkoff")
System_Ext(email_sms, "Email/SMS Service", "SendGrid/Twilio")
System_Ext(social, "Social Networks", "OAuth Providers")
System_Ext(cdn, "CDN", "CloudFront")

' === ОСНОВНЫЕ СВЯЗИ ===

' User -> CDN -> Gateway
Rel(author, cdn, "HTTPS", "")
Rel(backer, cdn, "HTTPS", "")
Rel(moderator, cdn, "HTTPS", "")
Rel(cdn, api_gateway, "HTTPS", "Входящий трафик")

' Gateway -> Services
Rel(api_gateway, auth_service, "HTTP/REST", "API запросы")
Rel(api_gateway, project_service, "HTTP/REST", "API запросы")
Rel(api_gateway, payment_service, "HTTP/REST", "API запросы")
Rel(api_gateway, search_service, "HTTP/REST", "API запросы")
Rel(api_gateway, moderation_service, "HTTP/REST", "API запросы")
Rel(web_frontend, api_gateway, "HTTP", "Client -> API")

' Services -> Data Layer
Rel(auth_service, postgres_primary, "JDBC", "Пользователи, сессии")
Rel(project_service, postgres_primary, "JDBC", "Проекты")
Rel(payment_service, postgres_primary, "JDBC", "Транзакции")
Rel(analytics_service, clickhouse, "HTTP", "Аналитика")
Rel(search_service, elasticsearch, "REST", "Поисковый индекс")
Rel(project_service, s3, "S3 API", "Медиафайлы")

' Services -> Infrastructure
Rel(auth_service, redis, "Redis Protocol", "Сессии")
Rel(project_service, redis, "Redis Protocol", "Кэш")
Rel(payment_service, rabbitmq, "AMQP", "События платежей")
Rel(notification_service, rabbitmq, "AMQP", "Обработка уведомлений")
Rel(project_service, rabbitmq, "AMQP", "События проектов")

' External Integrations
Rel(payment_service, payment_gateway, "HTTPS", "Платежи")
Rel(notification_service, email_sms, "HTTPS", "Уведомления")
Rel(auth_service, social, "OAuth2", "Социальный вход")

' Monitoring
Rel(prometheus, auth_service, "Metrics", "/metrics")
Rel(prometheus, postgres_primary, "Metrics", "БД метрики")
Rel(jaeger, api_gateway, "Traces", "Трассировка")
Rel(loki_stack, project_service, "Logs", "Сбор логов")

' Backup
Rel(postgres_primary, s3, "Backup", "Резервное копирование")

@enduml